<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wangziyang.mes.basedata.mapper.SpDeviceGroupMapper">
    <resultMap id="groupResultMap" type="com.wangziyang.mes.basedata.dto.SpDeviceGroupDTO">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="descr" property="descr"/>
        <result column="is_deleted" property="deleted"/>
        <result column="create_time" property="createTime"/>
        <result column="create_username" property="createUsername"/>
        <result column="update_time" property="updateTime"/>
        <result column="update_username" property="updateUsername"/>
        <result column="device_count" property="deviceCount"/>
    </resultMap>

    <select id="pageWithRelations" resultMap="groupResultMap">
        SELECT g.*,
               (SELECT COUNT(*) FROM sp_device_group_item dgi WHERE dgi.group_id = g.id) AS device_count
        FROM sp_device_group g
        WHERE g.is_deleted != '1'
        <if test="name != null and name != ''">
            AND g.name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="code != null and code != ''">
            AND g.code LIKE CONCAT('%', #{code}, '%')
        </if>
        ORDER BY g.create_time DESC
    </select>
</mapper>
